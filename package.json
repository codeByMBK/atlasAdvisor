{
  "name": "atlasadvisor",
  "version": "1.0.0",
  "private": true,
  "description": "Root package — provides backend dependencies for the Vercel serverless function. Local dev uses backend/ and frontend/ directly.",
  "scripts": {
    "dev:backend":  "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build":        "npm --prefix frontend run build",
    "test":         "npm --prefix backend test"
  },
  "dependencies": {
    "cors":               "^2.8.5",
    "dotenv":             "^16.4.5",
    "express":            "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "helmet":             "^8.1.0",
    "mongodb":            "^6.8.0",
    "multer":             "^2.1.1",
    "zod":                "^3.23.8"
  },
  "devDependencies": {
    "@types/cors":       "^2.8.17",
    "@types/express":    "^4.17.21",
    "@types/multer":     "^2.1.0",
    "@types/node":       "^20.14.0",
    "typescript":        "^5.5.2"
  }
}
